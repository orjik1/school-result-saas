{
  "name": "school-result-saas/school-result-saas",
  "description": "A production-ready multi-tenant Exam & Result Management SaaS WordPress plugin",
  "type": "wordpress-plugin",
  "license": "GPL-3.0-or-later",
  "authors": [
    {
      "name": "School Result SaaS Team",
      "email": "info@example.com"
    }
  ],
  "require": {
    "php": ">=7.6",
    "composer/installers": "^1.9",
    "dompdf/dompdf": "^1.2"
  },
  "require-dev": {
    "phpunit/phpunit": "^9.0",
    "phpcs": "^3.7"
  },
  "autoload": {
    "psr-4": {
      "SchoolResultSaaS\\": "includes/"
    }
  },
  "config": {
    "allow-plugins": {
      "composer/installers": true
    }
  }
}
